# GEMINI_API_KEY: Required for Gemini AI API calls.
# This value can be provided by your deployment environment or local .env files.
# Configure it using your hosting platform's secrets or a local .env file.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# This value is typically provided by your deployment environment or set locally.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BACKEND_URL: The URL for the backend API used by the frontend.
# Set to your local backend during development, or to your deployed backend URL.
BACKEND_URL="http://localhost:8080"
